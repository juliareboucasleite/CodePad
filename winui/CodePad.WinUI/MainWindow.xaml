<Window
    x:Class="CodePad.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="CodePad — Notas">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0" x:Name="MainMenu" />

        <TabView x:Name="NotesTabView" Grid.Row="1" IsAddTabButtonVisible="True" />

        <TextBlock x:Name="StatusText" Grid.Row="2" Margin="12,6" Text="Pronto" />
    </Grid>
</Window>
